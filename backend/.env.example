# Server Configuration
NODE_ENV=development
PORT=8081
FRONTEND_URL=http://localhost:3000

# Dev auth bypasses (no-token admin user, dev: passwords, fallback JWT secret).
# Must be explicitly set to true for local development without logins.
# Has no effect when NODE_ENV=production.
ALLOW_DEV_AUTH=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Supabase
# Local default URL after `npm run db:start`: http://127.0.0.1:54321
# Use the service_role key from `bun run db:status` for local development.
# On Render, use your hosted Supabase project URL and service_role key.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-or-hosted-service-role-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
# On Render, set this to your deployed frontend URL e.g. https://little-town.onrender.com
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Discord screenshot ingest (optional — omit both to disable the bot entirely)
# Requires the "Message Content Intent" enabled for the bot application in
# the Discord Developer Portal (Bot > Privileged Gateway Intents), otherwise
# attachments on messages the bot didn't send/get mentioned in are withheld.
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_SCREENSHOT_CHANNEL_ID=channel-id-to-watch-for-screenshots
