{
  "name": "littletown-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "npm install && tsc",
    "start": "node dist/index.js",
    "test": "node --test",
    "local": "bash scripts/dev-local.sh",
    "local:reset": "bash scripts/dev-local.sh --reset",
    "db:start": "bun x supabase start",
    "db:stop": "bun x supabase stop",
    "db:status": "bun x supabase status",
    "db:reset": "bun x supabase db reset",
    "db:push": "bun x supabase db push",
    "db:login": "bun x supabase login"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "npm run build && npm run start",
    "legacyWatch": true
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "dependencies": {
    "@sparticuz/chromium": "^131.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.2",
    "puppeteer-core": "^24.13.0",
    "typescript": "^5.2.2"
  }
}
