{
  "name": "littletown-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "bun x tsc",
    "start": "bun --bun dist/index.js",
    "test": "bun test",
    "db:start": "bun x supabase start",
    "db:stop": "bun x supabase stop",
    "db:status": "bun x supabase status",
    "db:reset": "bun x supabase db reset",
    "db:push": "bun x supabase db push",
    "db:login": "bun x supabase login",
    "dump-resources": "bun run scripts/dumpChannelToMarkdown.ts"
  },
  "nodemonConfig": {
    "watch": ["src"],
    "ext": "ts",
    "exec": "bun x tsc && bun --bun dist/index.js",
    "legacyWatch": true
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.2",
    "typescript": "^5.2.2",
    "zod": "^4.4.3"
  }
}
