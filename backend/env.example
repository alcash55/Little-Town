# Server Configuration
NODE_ENV=development
PORT=8081
FRONTEND_URL=http://localhost:8081

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Supabase
# Local default URL after `npm run db:start`: http://127.0.0.1:54321
# Use the service_role key from `bun run db:status` for local development.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-or-hosted-service-role-key

# Google Cloud Functions (for deployment)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_REGION=us-central1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:8081
CORS_CREDENTIALS=true
