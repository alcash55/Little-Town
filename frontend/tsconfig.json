{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "build",
    // Standalone Bun CLI script (node:fs/node:path, no @types/node in this
    // app's deps) — not part of the shipped app bundle, run directly with
    // `bun` instead of going through tsc/vite. See its own header comment.
    "src/components/Pages/BingoBoard/download-bingo-art.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
