# -------------------------------------------------------
# Little Town – Frontend Environment Variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# Base URL for the backend API
# e.g. http://localhost:8081 for local dev, https://api.yourdomain.com for production
VITE_BASEURL=

# -------------------------------------------------------
# Auth / Role Restrictions
# -------------------------------------------------------
# Auth is controlled by Vite's built-in import.meta.env.DEV flag — no env var needed.
#
# bun dev      → DEV=true  → all pages visible, no role checks (local development)
# bun build    → DEV=false → full role-based auth enforced
# bun preview  → DEV=false → full role-based auth enforced
